# Connessione al database.
# Sviluppo locale: file:./dev.db (SQLite)
# Produzione: stringa Postgres, es. postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="file:./dev.db"

# Chiave segreta per firmare le sessioni di accesso. Generane una nuova con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=""

# Usate solo in produzione al primo deploy per creare l'account amministratore.
# Dopo il primo accesso puoi cambiare la password dalla pagina di modifica dipendente.
INITIAL_ADMIN_EMAIL="admin@toret-to.it"
INITIAL_ADMIN_PASSWORD=""
