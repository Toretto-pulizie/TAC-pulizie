# Connessione al database Postgres (es. Neon).
# Aggiungere &pgbouncer=true se ci si connette tramite un connection pooler
# (necessario per evitare errori "cached plan must not change result type"
# dopo una migrazione dello schema).
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"

# Chiave segreta per firmare le sessioni di accesso. Generane una nuova con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=""

# Usate solo in produzione al primo deploy per creare l'account amministratore.
# Dopo il primo accesso puoi cambiare la password dalla pagina di modifica dipendente.
INITIAL_ADMIN_EMAIL="admin@toret-to.it"
INITIAL_ADMIN_PASSWORD=""
